{
  "name": "resona",
  "version": "1.0.0",
  "description": "A personal, platform-independent music database to track songs, artists, playlists, and listening history across services — without playing music.",
  "main": "index.js",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "mobile": "npm --workspace apps/mobile run start",
    "android": "npm --workspace apps/mobile run android",
    "ios": "npm --workspace apps/mobile run ios"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/makwana-chirag/resona.git"
  },
