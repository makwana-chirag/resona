{
  "name": "resona",
  "version": "1.0.0",
  "description": "A personal, platform-independent music database to track songs, artists, playlists, and listening history across services — without playing music.",
  "main": "index.js",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "start": "react-native start",
    "mobile": "npm --workspace apps/mobile run start",
    "android": "npm --workspace apps/mobile run android",
    "ios": "npm --workspace apps/mobile run ios"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/makwana-chirag/resona.git"
  },
  "keywords": [],
  "author": "Chirag Makwana",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/makwana-chirag/resona/issues"
  },
  "homepage": "https://github.com/makwana-chirag/resona#readme",
  "dependencies": {
    "@babel/runtime": "^7.29.2",
    "@react-native-community/blur": "^4.4.1",
    "@react-navigation/bottom-tabs": "^7.15.7",
    "@react-navigation/native": "^7.2.0",
    "react-native-safe-area-context": "^5.7.0",
    "react-native-screens": "^4.24.0"
  }
}
